generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  engine   = "library"
}

datasource db {
  provider = "postgresql"
}

model empresa {
  id_empresa  Int     @id @default(autoincrement())
  nombre      String  @db.VarChar(100)
  rut_empresa String? @unique @db.VarChar(12)
  esquema_db  String? @db.VarChar(50)

  usuarios              usuario[]
  clientes              cliente[]
  ordenes               orden_trabajo[]
  tipos_equipo          tipo_equipo[]
  cajas_nap             caja_nap[]
  planes                plan[]
  bodegas               bodega[]
  olts                  olt[]
  canales_wa            canal_whatsapp[]
  puntos_cobertura      punto_cobertura[]
  contratos             contrato[]
  tickets               ticket[]
  intentos_fallidos     intento_fallido[]
  ordenes_ingreso       orden_ingreso[]
  unidades              unidad_equipo[]
  prospectos            prospecto[]
  configuraciones_seo   configuracion_seo[]
  movimientos_origen    movimiento_inventario[] @relation("empresa_origen")
  movimientos_destino   movimiento_inventario[] @relation("empresa_destino")
  transferencias_origen  transferencia_equipo[]  @relation("empresa_origen")
  transferencias_destino transferencia_equipo[]  @relation("empresa_destino")
  prestamos             prestamo_externo[]
}

model usuario {
  id_usuario      Int       @id @default(autoincrement())
  id_empresa      Int?
  nombre_completo String    @db.VarChar(80)
  nombre_usuario  String?   @unique @db.VarChar(50)
  email           String?   @unique @db.VarChar(120)
  password_hash   String    @db.VarChar(72)
  activo          Boolean   @default(true)
  fecha_creacion  DateTime  @default(now())
  es_password_temporal Boolean @default(true)

  empresa              empresa?                  @relation(fields: [id_empresa], references: [id_empresa])
  roles                usuario_rol[]
  log_auditoria        log_auditoria[]
  tickets_asignados    ticket[]
  historial_equipos    historial_estado_equipo[]
  ordenes_tecnico      orden_trabajo[]           @relation("ot_tecnico")
  historial_ot         historial_ot[]
  ordenes_ingreso      orden_ingreso[]
  bajas_equipo         baja_equipo[]
  movimientos          movimiento_inventario[]
  transferencias       transferencia_equipo[]
  prospectos           prospecto[]
  lista_negra_registro lista_negra[]
}

model rol {
  id_rol      Int     @id @default(autoincrement())
  nombre_rol  String  @unique @db.VarChar(50)
  descripcion String? @db.Text
  usuarios    usuario_rol[]
}

model usuario_rol {
  id_usuario_rol   Int      @id @default(autoincrement())
  id_usuario       Int?
  id_rol           Int
  fecha_asignacion DateTime @default(now()) @db.Date
  usuario          usuario? @relation(fields: [id_usuario], references: [id_usuario])
  rol              rol      @relation(fields: [id_rol], references: [id_rol])
  @@unique([id_usuario, id_rol])
}

model log_auditoria {
  id_log              BigInt   @id @default(autoincrement())
  id_usuario          Int?
  accion              String   @db.VarChar(100)
  entidad_afectada    String?  @db.VarChar(80)
  id_entidad_afectada Int?
  valor_anterior      Json?
  valor_nuevo         Json?
  ip_origen           String?  @db.VarChar(45)
  fecha_hora          DateTime @default(now())
  usuario             usuario? @relation(fields: [id_usuario], references: [id_usuario])
}

model cliente {
  id_cliente           Int      @id @default(autoincrement())
  id_empresa           Int?
  rut                  String?  @unique @db.VarChar(12)
  nombre_completo      String   @db.VarChar(120)
  email                String?  @db.VarChar(120)
  telefono             String?  @db.VarChar(20)
  password_portal_hash String?  @db.VarChar(72)
  estado               String   @db.VarChar(20)
  es_conflictivo       Boolean  @default(false)
  obs_conflictivo      String?  @db.VarChar(500)
  importado_masivo     Boolean  @default(false)
  fecha_creacion       DateTime @default(now())

  empresa              empresa?               @relation(fields: [id_empresa], references: [id_empresa])
  direcciones          direccion_servicio[]
  contratos            contrato[]
  ordenes              orden_trabajo[]
  lista_negra          lista_negra[]
  tickets              ticket[]
  sesiones             sesion_portal[]
  consentimientos      consentimiento_cookies[]
  monitoreo            monitoreo_ont[]
  mensajes_wa          mensaje_whatsapp[]
  conversaciones       conversacion_bot[]
  prospectos           prospecto[]
  pagos                pago[]
  unidades_instaladas  unidad_equipo[]
  puertos_nap          puerto_nap[]
  log_notificacion     log_notificacion[]
}

model direccion_servicio {
  id_direccion       Int     @id @default(autoincrement())
  id_cliente         Int?
  direccion_completa String  @db.VarChar(200)
  comuna             String  @db.VarChar(80)
  ciudad             String? @db.VarChar(80)
  es_principal       Boolean @default(true)
  cliente            cliente? @relation(fields: [id_cliente], references: [id_cliente])
  ordenes            orden_trabajo[]
}

model plan {
  id_plan          Int      @id @default(autoincrement())
  id_empresa       Int?
  nombre_comercial String   @db.VarChar(100)
  tipo_plan        String   @db.VarChar(20)
  tipo_cliente     String   @db.VarChar(20)
  velocidad_mbps   Int?
  precio_mensual   Decimal  @db.Decimal(10, 2)
  descripcion      String?  @db.Text
  activo           Boolean  @default(true)
  empresa          empresa? @relation(fields: [id_empresa], references: [id_empresa])
  contratos        contrato[]
  cotizaciones     cotizacion[]
}

model contrato {
  id_contrato      Int      @id @default(autoincrement())
  id_cliente       Int?
  id_plan          Int?
  id_empresa       Int?
  fecha_inicio     DateTime @db.Date
  dia_vencimiento  Int      @db.SmallInt
  estado           String   @db.VarChar(20)
  fecha_suspension DateTime? @db.Date
  cliente          cliente?  @relation(fields: [id_cliente], references: [id_cliente])
  plan             plan?     @relation(fields: [id_plan], references: [id_plan])
  empresa          empresa?  @relation(fields: [id_empresa], references: [id_empresa])
  facturas         factura[]
  credenciales_tvip credenciales_tvip?
}

model factura {
  id_factura        Int      @id @default(autoincrement())
  id_contrato       Int?
  periodo_mes       Int      @db.SmallInt
  periodo_anio      Int      @db.SmallInt
  monto             Decimal? @db.Decimal(10, 2)
  fecha_emision     DateTime? @db.Date
  fecha_limite_pago DateTime  @db.Date
  estado            String    @db.VarChar(20)
  contrato          contrato? @relation(fields: [id_contrato], references: [id_contrato])
  pagos             pago[]
}

model pago {
  id_pago             Int      @id @default(autoincrement())
  id_factura          Int?
  id_cliente          Int?
  monto               Decimal  @db.Decimal(10, 2)
  fecha_pago          DateTime
  codigo_transaccion  String?  @unique @db.VarChar(100)
  pasarela            String   @db.VarChar(30)
  token_transaccional String?  @db.VarChar(200)
  comprobante_pdf_url String?  @db.Text
  factura             factura? @relation(fields: [id_factura], references: [id_factura])
  cliente             cliente? @relation(fields: [id_cliente], references: [id_cliente])
}

model ticket {
  id_ticket            Int      @id @default(autoincrement())
  id_cliente           Int?
  id_empresa           Int?
  id_usuario_asignado  Int?
  id_categoria         Int
  id_conversacion_bot  Int?     @unique
  codigo_seguimiento   String?  @unique @db.VarChar(20)
  prioridad            String   @db.VarChar(10)
  estado               String   @db.VarChar(20)
  descripcion          String?  @db.Text
  fecha_creacion       DateTime @default(now())
  fecha_cierre         DateTime?
  origen               String?  @db.VarChar(20)
  resuelto_remotamente Boolean  @default(false)
  cliente              cliente?         @relation(fields: [id_cliente], references: [id_cliente])
  empresa              empresa?         @relation(fields: [id_empresa], references: [id_empresa])
  usuario_asignado     usuario?         @relation(fields: [id_usuario_asignado], references: [id_usuario])
  categoria            categoria_falla  @relation(fields: [id_categoria], references: [id_categoria])
  conversacion_bot     conversacion_bot? @relation(fields: [id_conversacion_bot], references: [id_conversacion])
  orden_trabajo        orden_trabajo?
}

model plantilla_notificacion {
  id_plantilla    Int     @id @default(autoincrement())
  tipo_evento     String? @db.VarChar(60)
  canal           String  @db.VarChar(20)
  contenido_texto String? @db.Text
  activa          Boolean @default(true)
  notificaciones  log_notificacion[]
}

model log_notificacion {
  id_notificacion BigInt    @id @default(autoincrement())
  id_cliente      Int?
  id_plantilla    Int?
  canal           String?   @db.VarChar(20)
  fecha_envio     DateTime?
  estado_envio    String?   @db.VarChar(20)
  cliente         cliente?                @relation(fields: [id_cliente], references: [id_cliente])
  plantilla       plantilla_notificacion? @relation(fields: [id_plantilla], references: [id_plantilla])
}

model tipo_equipo {
  id_tipo_equipo            Int     @id @default(autoincrement())
  id_empresa                Int?
  nombre                    String  @db.VarChar(100)
  categoria                 String? @db.VarChar(40)
  requiere_serie_individual Boolean?
  ficha_tecnica_pdf_url     String? @db.Text
  activo                    Boolean @default(true)
  empresa                   empresa?                 @relation(fields: [id_empresa], references: [id_empresa])
  unidades                  unidad_equipo[]
  stock                     stock_consumible[]
  uso_ot                    uso_material_ot[]
  detalles_ingreso          detalle_orden_ingreso[]
  movimientos               movimiento_inventario[]
}

model unidad_equipo {
  id_unidad             Int      @id @default(autoincrement())
  id_tipo_equipo        Int?
  id_empresa            Int?
  numero_serie          String   @unique @db.VarChar(80)
  modelo                String?  @db.VarChar(80)
  estado                String   @db.VarChar(30)
  fecha_adquisicion     DateTime? @db.Date
  fecha_venc_garantia   DateTime? @db.Date
  diagnostico_tecnico   String?  @db.Text
  id_cliente_instalado  Int?
  id_bodega_actual      Int?
  numero_poste          String?  @db.VarChar(30)
  id_caja_nap           Int?
  tipo_equipo           tipo_equipo?  @relation(fields: [id_tipo_equipo], references: [id_tipo_equipo])
  empresa               empresa?      @relation(fields: [id_empresa], references: [id_empresa])
  cliente_instalado     cliente?      @relation(fields: [id_cliente_instalado], references: [id_cliente])
  bodega_actual         bodega?       @relation(fields: [id_bodega_actual], references: [id_bodega])
  caja_nap              caja_nap?     @relation(fields: [id_caja_nap], references: [id_caja_nap])
  historial_estado      historial_estado_equipo[]
  historial_conexion    historial_conexion_ont[]
  monitoreo             monitoreo_ont[]
  uso_ot                uso_material_ot[]
  bajas                 baja_equipo[]
  prestamos             prestamo_externo[]
  movimientos           movimiento_inventario[]
}

model caja_nap {
  id_caja_nap        Int      @id @default(autoincrement())
  id_empresa         Int?
  id_mufa            Int?
  identificador_unico String? @unique @db.VarChar(50)
  numero_poste       String?  @db.VarChar(30)
  zona               String?  @db.VarChar(80)
  capacidad_puertos  Int?     @db.SmallInt
  latitud            Decimal? @db.Decimal(9, 6)
  longitud           Decimal? @db.Decimal(9, 6)
  empresa            empresa? @relation(fields: [id_empresa], references: [id_empresa])
  mufa               mufa?    @relation(fields: [id_mufa], references: [id_mufa])
  puertos            puerto_nap[]
  unidades           unidad_equipo[]
  monitoreo          monitoreo_ont[]
}

model orden_trabajo {
  id_ot                Int      @id @default(autoincrement())
  id_empresa           Int?
  id_cliente           Int?
  id_tecnico           Int?
  id_tecnico_externo   Int?
  id_direccion         Int?
  id_ticket            Int?     @unique
  tipo_ot              String   @db.VarChar(20)
  prioridad            String   @db.VarChar(10)
  estado               String   @db.VarChar(25)
  fecha_creacion       DateTime @default(now())
  fecha_programada     DateTime? @db.Date
  fecha_completada     DateTime?
  potencia_optica_dbm  Decimal? @db.Decimal(5, 2)
  observaciones        String?  @db.Text
  resuelto_remotamente Boolean  @default(false)
  empresa              empresa?         @relation(fields: [id_empresa], references: [id_empresa])
  cliente              cliente?         @relation(fields: [id_cliente], references: [id_cliente])
  tecnico              usuario?         @relation("ot_tecnico", fields: [id_tecnico], references: [id_usuario])
  tecnico_externo      tecnico_externo? @relation(fields: [id_tecnico_externo], references: [id_tecnico_ext])
  direccion            direccion_servicio? @relation(fields: [id_direccion], references: [id_direccion])
  ticket               ticket?          @relation(fields: [id_ticket], references: [id_ticket])
  historial            historial_ot[]
  materiales           uso_material_ot[]
  fotos                evidencia_foto[]
  llamada              llamada_cortes?
}

model historial_ot {
  id_historial_ot BigInt    @id @default(autoincrement())
  id_ot           Int?
  id_usuario      Int?
  estado_anterior String?   @db.VarChar(25)
  estado_nuevo    String?   @db.VarChar(25)
  observaciones   String?   @db.Text
  fecha_hora      DateTime  @default(now())
  orden_trabajo   orden_trabajo? @relation(fields: [id_ot], references: [id_ot])
  usuario         usuario?       @relation(fields: [id_usuario], references: [id_usuario])
}

model categoria_falla {
  id_categoria Int     @id @default(autoincrement())
  nombre       String  @db.VarChar(80)
  sla_horas    Int?    @db.SmallInt
  tickets      ticket[]
}

model uso_material_ot {
  id_uso         Int     @id @default(autoincrement())
  id_ot          Int?
  id_tipo_equipo Int?
  id_unidad      Int?
  cantidad       Decimal @db.Decimal(10, 2)
  orden_trabajo  orden_trabajo? @relation(fields: [id_ot], references: [id_ot])
  tipo_equipo    tipo_equipo?   @relation(fields: [id_tipo_equipo], references: [id_tipo_equipo])
  unidad         unidad_equipo? @relation(fields: [id_unidad], references: [id_unidad])
}

model evidencia_foto {
  id_foto        Int      @id @default(autoincrement())
  id_ot          Int?
  url_cloudinary String   @db.Text
  formato        String?  @db.VarChar(5)
  tamano_kb      Int?
  fecha_subida   DateTime @default(now())
  orden_trabajo  orden_trabajo? @relation(fields: [id_ot], references: [id_ot])
}

model llamada_cortes {
  id_llamada    Int      @id @default(autoincrement())
  id_ot         Int?     @unique
  resultado     String   @db.VarChar(15)
  observaciones String?  @db.Text
  fecha_llamada DateTime @default(now())
  orden_trabajo orden_trabajo? @relation(fields: [id_ot], references: [id_ot])
}

model lista_negra {
  id_vetado           Int      @id @default(autoincrement())
  id_cliente          Int?
  rut_vetado          String   @db.VarChar(12)
  direccion_vetada    String?  @db.Text
  motivo              String   @db.Text
  fecha_registro      DateTime @default(now()) @db.Date
  id_usuario_registro Int?
  cliente             cliente? @relation(fields: [id_cliente], references: [id_cliente])
  usuario_registro    usuario? @relation(fields: [id_usuario_registro], references: [id_usuario])
}

model bodega {
  id_bodega   Int     @id @default(autoincrement())
  id_empresa  Int?
  nombre      String  @db.VarChar(60)
  direccion   String? @db.VarChar(200)
  activa      Boolean @default(true)
  empresa     empresa?         @relation(fields: [id_empresa], references: [id_empresa])
  stock       stock_consumible[]
  ordenes_ingreso orden_ingreso[]
  unidades    unidad_equipo[]
  movimientos_origen  movimiento_inventario[] @relation("bodega_origen")
  movimientos_destino movimiento_inventario[] @relation("bodega_destino")
}

model stock_consumible {
  id_stock            Int     @id @default(autoincrement())
  id_tipo_equipo      Int?
  id_bodega           Int?
  cantidad_disponible Decimal @db.Decimal(10, 2)
  umbral_minimo       Decimal? @db.Decimal(10, 2)
  tipo_equipo         tipo_equipo? @relation(fields: [id_tipo_equipo], references: [id_tipo_equipo])
  bodega              bodega?      @relation(fields: [id_bodega], references: [id_bodega])
}

model proveedor {
  id_proveedor     Int     @id @default(autoincrement())
  nombre_comercial String  @db.VarChar(100)
  rut_proveedor    String? @db.VarChar(12)
  contacto         String? @db.VarChar(80)
  telefono         String? @db.VarChar(20)
  email            String? @db.VarChar(120)
  ordenes_ingreso  orden_ingreso[]
}

model orden_ingreso {
  id_orden            Int      @id @default(autoincrement())
  id_proveedor        Int?
  id_bodega           Int?
  id_empresa          Int?
  id_usuario_registro Int?
  fecha_creacion      DateTime? @db.Date
  fecha_recepcion     DateTime? @db.Date
  estado              String?   @db.VarChar(25)
  factura_proveedor   String?   @db.VarChar(50)
  proveedor           proveedor?   @relation(fields: [id_proveedor], references: [id_proveedor])
  bodega              bodega?      @relation(fields: [id_bodega], references: [id_bodega])
  empresa             empresa?     @relation(fields: [id_empresa], references: [id_empresa])
  usuario_registro    usuario?     @relation(fields: [id_usuario_registro], references: [id_usuario])
  detalles            detalle_orden_ingreso[]
}

model detalle_orden_ingreso {
  id_detalle          Int          @id @default(autoincrement())
  id_orden            Int?
  id_tipo_equipo      Int?
  cantidad_solicitada Int
  cantidad_recibida   Int          @default(0)
  orden               orden_ingreso? @relation(fields: [id_orden], references: [id_orden])
  tipo_equipo         tipo_equipo?   @relation(fields: [id_tipo_equipo], references: [id_tipo_equipo])
}

model historial_estado_equipo {
  id_historial    BigInt        @id @default(autoincrement())
  id_unidad       Int?
  id_usuario      Int?
  estado_anterior String?       @db.VarChar(30)
  estado_nuevo    String?       @db.VarChar(30)
  motivo          String?       @db.Text
  fecha_hora      DateTime      @default(now())
  unidad          unidad_equipo? @relation(fields: [id_unidad], references: [id_unidad])
  usuario         usuario?       @relation(fields: [id_usuario], references: [id_usuario])
}

model movimiento_inventario {
  id_movimiento     BigInt    @id @default(autoincrement())
  id_tipo_equipo    Int?
  id_unidad         Int?
  id_empresa_origen Int?
  id_empresa_destino Int?
  id_bodega_origen  Int?
  id_bodega_destino Int?
  id_usuario        Int?
  tipo_movimiento   String?   @db.VarChar(30)
  cantidad          Decimal   @default(1) @db.Decimal(10, 2)
  fecha             DateTime  @default(now())
  referencia_id     Int?
  tipo_equipo       tipo_equipo?    @relation(fields: [id_tipo_equipo], references: [id_tipo_equipo])
  unidad            unidad_equipo?  @relation(fields: [id_unidad], references: [id_unidad])
  empresa_origen    empresa?        @relation("empresa_origen", fields: [id_empresa_origen], references: [id_empresa])
  empresa_destino   empresa?        @relation("empresa_destino", fields: [id_empresa_destino], references: [id_empresa])
  bodega_origen     bodega?         @relation("bodega_origen", fields: [id_bodega_origen], references: [id_bodega])
  bodega_destino    bodega?         @relation("bodega_destino", fields: [id_bodega_destino], references: [id_bodega])
  usuario           usuario?        @relation(fields: [id_usuario], references: [id_usuario])
}

model prestamo_externo {
  id_prestamo            Int      @id @default(autoincrement())
  id_unidad              Int?
  id_empresa_prestamista Int?
  destinatario           String?  @db.VarChar(100)
  motivo                 String?  @db.Text
  fecha_salida           DateTime? @db.Date
  fecha_retorno_esperada DateTime? @db.Date
  fecha_retorno_real     DateTime? @db.Date
  estado                 String?  @db.VarChar(20)
  condicion_retorno      String?  @db.Text
  unidad                 unidad_equipo? @relation(fields: [id_unidad], references: [id_unidad])
  empresa_prestamista    empresa?       @relation(fields: [id_empresa_prestamista], references: [id_empresa])
}

model baja_equipo {
  id_baja               Int      @id @default(autoincrement())
  id_unidad             Int?
  id_usuario            Int?
  motivo_baja           String   @db.Text
  tipo_baja             String?  @db.VarChar(20)
  donacion_destinatario String?  @db.VarChar(150)
  fecha_baja            DateTime? @db.Date
  unidad                unidad_equipo? @relation(fields: [id_unidad], references: [id_unidad])
  usuario               usuario?       @relation(fields: [id_usuario], references: [id_usuario])
}

model sesion_portal {
  id_sesion        BigInt    @id @default(autoincrement())
  id_cliente       Int?
  token            String    @db.VarChar(255)
  fecha_inicio     DateTime?
  fecha_expiracion DateTime?
  ip_origen        String?   @db.VarChar(45)
  cliente          cliente?  @relation(fields: [id_cliente], references: [id_cliente])
}

model intento_fallido {
  id_intento      BigInt    @id @default(autoincrement())
  id_empresa      Int?
  ip_address      String    @db.VarChar(45)
  rut_intentado   String?   @db.VarChar(12)
  timestamp       DateTime  @default(now())
  bloqueado_hasta DateTime?
  empresa         empresa?  @relation(fields: [id_empresa], references: [id_empresa])
}

model punto_cobertura {
  id_punto           Int     @id @default(autoincrement())
  id_empresa         Int?
  latitud            Decimal @db.Decimal(9, 6)
  longitud           Decimal @db.Decimal(9, 6)
  densidad_cobertura Decimal? @db.Decimal(5, 2)
  tipo_cobertura     String?  @db.VarChar(20)
  empresa            empresa? @relation(fields: [id_empresa], references: [id_empresa])
}

model consentimiento_cookies {
  id_consentimiento  BigInt    @id @default(autoincrement())
  id_cliente         Int?
  ip_anonimizada     String?   @db.VarChar(45)
  version_documento  String?   @db.VarChar(20)
  fecha_aceptacion   DateTime?
  acepto             Boolean
  cliente            cliente?  @relation(fields: [id_cliente], references: [id_cliente])
}

model configuracion_seo {
  id_seo              Int      @id @default(autoincrement())
  id_empresa          Int
  seccion_url         String   @db.VarChar(200)
  meta_titulo         String?  @db.VarChar(70)
  meta_descripcion    String?  @db.VarChar(160)
  og_tags             Json?
  fecha_actualizacion DateTime @default(now())
  empresa             empresa  @relation(fields: [id_empresa], references: [id_empresa])
  @@unique([id_empresa, seccion_url])
}

model tecnico_externo {
  id_tecnico_ext  Int     @id @default(autoincrement())
  nombre_completo String  @db.VarChar(120)
  empresa         String? @db.VarChar(100)
  telefono        String? @db.VarChar(20)
  activo          Boolean @default(true)
  ordenes         orden_trabajo[]
}

model olt {
  id_olt      Int     @id @default(autoincrement())
  id_empresa  Int?
  nombre      String? @db.VarChar(80)
  ubicacion   String? @db.VarChar(200)
  ip_gestion  String? @db.VarChar(45)
  empresa     empresa?      @relation(fields: [id_empresa], references: [id_empresa])
  tarjetas    tarjeta_pon[]
}

model tarjeta_pon {
  id_tarjeta     Int    @id @default(autoincrement())
  id_olt         Int?
  numero_tarjeta Int?   @db.SmallInt
  total_puertos  Int?   @db.SmallInt
  olt            olt?   @relation(fields: [id_olt], references: [id_olt])
  mufas          mufa[]
}

model mufa {
  id_mufa        Int     @id @default(autoincrement())
  id_tarjeta_pon Int?
  identificador  String? @db.VarChar(50)
  ubicacion      String? @db.VarChar(200)
  tarjeta_pon    tarjeta_pon? @relation(fields: [id_tarjeta_pon], references: [id_tarjeta])
  cajas_nap      caja_nap[]
}

model puerto_nap {
  id_puerto           Int     @id @default(autoincrement())
  id_caja_nap         Int?
  numero_puerto       Int?    @db.SmallInt
  estado              String? @db.VarChar(10)
  id_cliente_asociado Int?
  caja_nap            caja_nap? @relation(fields: [id_caja_nap], references: [id_caja_nap])
  cliente_asociado    cliente?  @relation(fields: [id_cliente_asociado], references: [id_cliente])
}

model monitoreo_ont {
  id_monitoreo        BigInt   @id @default(autoincrement())
  id_unidad           Int?
  id_cliente          Int?
  id_caja_nap         Int?
  potencia_actual_dbm Decimal? @db.Decimal(5, 2)
  timestamp_medicion  DateTime @default(now())
  estado_conexion     String?  @db.VarChar(15)
  unidad              unidad_equipo? @relation(fields: [id_unidad], references: [id_unidad])
  cliente             cliente?       @relation(fields: [id_cliente], references: [id_cliente])
  caja_nap            caja_nap?      @relation(fields: [id_caja_nap], references: [id_caja_nap])
}

model historial_conexion_ont {
  id_historial_ont BigInt        @id @default(autoincrement())
  id_unidad        Int?
  evento           String?       @db.VarChar(15)
  timestamp        DateTime      @default(now())
  unidad           unidad_equipo? @relation(fields: [id_unidad], references: [id_unidad])
}

model prospecto {
  id_prospecto         Int      @id @default(autoincrement())
  id_empresa           Int?
  id_usuario_comercial Int?
  id_cliente           Int?     @unique
  rut                  String?  @db.VarChar(12)
  nombre_completo      String?  @db.VarChar(120)
  email                String?  @db.VarChar(120)
  telefono             String?  @db.VarChar(20)
  direccion            String?  @db.VarChar(200)
  estado_pipeline      String?  @db.VarChar(30)
  motivo_perdida       String?  @db.VarChar(30)
  tiempo_conversion_dias Int?
  fecha_creacion       DateTime @default(now())
  fecha_conversion     DateTime? @db.Date
  empresa              empresa? @relation(fields: [id_empresa], references: [id_empresa])
  usuario_comercial    usuario? @relation(fields: [id_usuario_comercial], references: [id_usuario])
  cliente              cliente? @relation(fields: [id_cliente], references: [id_cliente])
  cotizaciones         cotizacion[]
}

model cotizacion {
  id_cotizacion           Int      @id @default(autoincrement())
  id_prospecto            Int?
  id_plan                 Int?
  pdf_url                 String?  @db.Text
  fecha_envio             DateTime?
  factibilidad_verificada Boolean  @default(false)
  prospecto               prospecto? @relation(fields: [id_prospecto], references: [id_prospecto])
  plan                    plan?      @relation(fields: [id_plan], references: [id_plan])
}

model canal_whatsapp {
  id_canal        Int     @id @default(autoincrement())
  id_empresa      Int?
  numero_telefono String? @unique @db.VarChar(20)
  nombre_canal    String? @db.VarChar(80)
  activo          Boolean @default(true)
  empresa         empresa?             @relation(fields: [id_empresa], references: [id_empresa])
  plantillas      plantilla_whatsapp[]
  mensajes        mensaje_whatsapp[]
  conversaciones  conversacion_bot[]
}

model plantilla_whatsapp {
  id_plantilla_wa  Int     @id @default(autoincrement())
  id_canal         Int?
  nombre_plantilla String? @db.VarChar(80)
  contenido        String? @db.Text
  tipo_uso         String? @db.VarChar(40)
  canal            canal_whatsapp?    @relation(fields: [id_canal], references: [id_canal])
  mensajes         mensaje_whatsapp[]
}

model mensaje_whatsapp {
  id_mensaje_wa   BigInt    @id @default(autoincrement())
  id_canal        Int?
  id_cliente      Int?
  id_plantilla_wa Int?
  contenido       String?   @db.Text
  timestamp       DateTime  @default(now())
  origen          String?   @db.VarChar(10)
  estado          String?   @db.VarChar(15)
  canal           canal_whatsapp?     @relation(fields: [id_canal], references: [id_canal])
  cliente         cliente?            @relation(fields: [id_cliente], references: [id_cliente])
  plantilla_wa    plantilla_whatsapp? @relation(fields: [id_plantilla_wa], references: [id_plantilla_wa])
}

model conversacion_bot {
  id_conversacion Int       @id @default(autoincrement())
  id_cliente      Int?
  id_canal_wa     Int?
  plataforma      String?   @db.VarChar(20)
  fecha_inicio    DateTime  @default(now())
  fecha_fin       DateTime?
  derivada_humano Boolean   @default(false)
  cliente         cliente?        @relation(fields: [id_cliente], references: [id_cliente])
  canal_wa        canal_whatsapp? @relation(fields: [id_canal_wa], references: [id_canal])
  mensajes        mensaje_bot[]
  ticket          ticket?
}

model mensaje_bot {
  id_mensaje      BigInt           @id @default(autoincrement())
  id_conversacion Int?
  rol             String?          @db.VarChar(15)
  contenido       String?          @db.Text
  timestamp       DateTime         @default(now())
  datos_sensibles Boolean?
  conversacion    conversacion_bot? @relation(fields: [id_conversacion], references: [id_conversacion])
}

model credenciales_tvip {
  id_credencial      Int      @id @default(autoincrement())
  id_contrato        Int?     @unique
  usuario_tvip       String?  @db.VarChar(80)
  password_tvip_hash String?  @db.VarChar(72)
  fecha_generacion   DateTime @default(now())
  contrato           contrato? @relation(fields: [id_contrato], references: [id_contrato])
}

model transferencia_equipo {
  id_transferencia    Int      @id @default(autoincrement())
  id_empresa_origen   Int?
  id_empresa_destino  Int?
  id_usuario_registro Int?
  fecha_transferencia DateTime? @db.Date
  observaciones       String?   @db.Text
  empresa_origen      empresa? @relation("empresa_origen", fields: [id_empresa_origen], references: [id_empresa])
  empresa_destino     empresa? @relation("empresa_destino", fields: [id_empresa_destino], references: [id_empresa])
  usuario_registro    usuario? @relation(fields: [id_usuario_registro], references: [id_usuario])
}
